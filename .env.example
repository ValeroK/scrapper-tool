# scrapper-tool — environment variables (example)
#
# Copy to .env and edit. Every variable below is OPTIONAL — the library
# has working defaults for "ultimate scraper" use. Override only what you
# need. Full reference: docs/SETTINGS.md
#
# Loading: scrapper-tool itself does NOT load .env automatically. Either:
#   1. export the vars in your shell,
#   2. use `uv run --env-file .env ...` / `docker compose up`,
#   3. or load .env in your own entry point (python-dotenv, etc).

# =============================================================================
# Pattern E — LLM-agent layer (v0.3.0+)
# =============================================================================

# --- Browser backend ---------------------------------------------------------
# Choices: camoufox (default — 0% headless detection, ~200 MB RAM/instance,
#                    ~42 s/bypass — best for protected sites)
#          patchright (~67% detection reduction, faster, lower RAM —
#                      good for unprotected/lightly-protected sites)
#          zendriver (CDP-direct, lightest, ~75% bypass — when Playwright
#                     itself is the giveaway)
#          scrapling (reuses [hostile] extra)
#          botasaurus (decorator paradigm, humanlike behavior emulation)
SCRAPPER_TOOL_AGENT_BROWSER=camoufox

# Per-session fingerprint generator (UA / canvas / WebGL / audio / fonts).
# Choices: browserforge (default; ignored by Camoufox which has its own)
#          none
SCRAPPER_TOOL_AGENT_FINGERPRINT=browserforge

# Behavior shaping for input timing (defeats DataDome behavioral detection).
# Choices: humanlike (default; jittered keystrokes, bezier mouse paths)
#          fast (skip delays — for unprotected sites)
#          off (no shaping at all)
SCRAPPER_TOOL_AGENT_BEHAVIOR=humanlike

# Run with a visible browser window (useful for debugging).
SCRAPPER_TOOL_AGENT_HEADFUL=0

# Optional outbound proxy (HTTP/SOCKS) passed through to the browser.
# Format: "http://user:pass@host:port" or "socks5://host:port"
# SCRAPPER_TOOL_AGENT_PROXY=http://localhost:8888

# --- LLM backend -------------------------------------------------------------
# Choices: ollama (default — local, free)
#          openai_compat (any OpenAI-compatible HTTP server)
#          llama_cpp (alias for openai_compat — llama.cpp's `server` mode)
#          vllm (alias for openai_compat — vLLM)
SCRAPPER_TOOL_AGENT_LLM=ollama

# Local model tag. Default = qwen3-vl:8b (vision-language, recommended for
# 16 GB VRAM at Q4_K_M, ~6 GB model + ~1.4 GB vision encoder + KV cache).
#
# Recommendations by hardware (May 2026):
#   qwen3-vl:8b               16 GB VRAM — DEFAULT. Best agentic + UI grounding
#                             at this tier. Q4_K_M ~6.1 GB, Q8_0 fits in 16 GB
#                             for higher OCR accuracy.
#   qwen3-vl:4b               8 GB VRAM — recommended. Q4_K_M ~3.3 GB leaves
#                             headroom for vision encoder + browser process.
#   qwen3-vl:30b              ~20 GB+ VRAM (MoE A3B) — heavier, best quality.
#   qwen3-vl:2b               4-6 GB VRAM — fallback for laptops / low-end GPUs.
#   qwen3-coder:30b           Text-only, top-tier function calling. Vision
#                             auto-disabled. Use for DOM-only flows on 24 GB+.
#   deepseek-v3.2             Heaviest hardware; best general reasoning.
SCRAPPER_TOOL_AGENT_MODEL=qwen3-vl:8b

# Base URL of the local LLM server. Doubles as base URL for openai_compat /
# llama_cpp / vllm backends.
#
# === Common values ===
#   http://localhost:11434                  — local Ollama (default).
#   http://ollama:11434                     — Ollama service inside docker-compose.
#   http://localhost:1234                   — local LM Studio (host).
#   http://host.docker.internal:1234        — LM Studio on host, called
#                                              from inside a Docker container.
#                                              Requires `extra_hosts` in compose.
#   http://localhost:8080                   — local llama.cpp `server` mode.
#   http://localhost:8000                   — local vLLM.
SCRAPPER_TOOL_AGENT_OLLAMA_URL=http://localhost:11434

# ----- LM Studio example (uncomment + set SCRAPPER_TOOL_AGENT_LLM=openai_compat) -----
# LM Studio exposes an OpenAI-compatible API on port 1234 by default.
# 1. Open LM Studio → Local Server tab → Start Server.
# 2. Note the model name shown there (e.g. "qwen3-vl-8b-instruct").
# 3. Then override:
# SCRAPPER_TOOL_AGENT_LLM=openai_compat
# SCRAPPER_TOOL_AGENT_OLLAMA_URL=http://localhost:1234       # or http://host.docker.internal:1234 from Docker
# SCRAPPER_TOOL_AGENT_MODEL=qwen3-vl-8b-instruct

# --- Run budget --------------------------------------------------------------
# E2 (agent_browse) max steps before giving up.
SCRAPPER_TOOL_AGENT_MAX_STEPS=20
# Per-call timeout in seconds (applies to both E1 and E2).
SCRAPPER_TOOL_AGENT_TIMEOUT_S=120

# --- ToS / safety ------------------------------------------------------------
# When 1/true, the agent fetches /robots.txt and refuses if disallowed.
SCRAPPER_TOOL_AGENT_RESPECT_ROBOTS=1

# =============================================================================
# CAPTCHA solver cascade
# =============================================================================
#
# The "auto" cascade:
#   Tier 0  Camoufox auto-pass (free, $0)        → most CF Turnstile
#   Tier 1  Theyka/Turnstile-Solver (free, $0)   → CF Turnstile fallback
#   Tier 2  paid solver (only if API key set)    → hCaptcha / reCAPTCHA / etc.
#
# Choices: auto (default — recommended)
#          camoufox-auto (Tier 0 only)
#          theyka (Tier 1 only)
#          capsolver | nopecha | twocaptcha (paid, requires API key)
#          none (raise on captcha)
SCRAPPER_TOOL_CAPTCHA_SOLVER=auto

# Paid-solver API key. Leave unset to keep the cascade free; setting this
# enables Tier 2 escalation. Get one from your chosen vendor's dashboard.
# SCRAPPER_TOOL_CAPTCHA_KEY=sk_capsolver_xxx_replace_me

# Which paid vendor to use when SCRAPPER_TOOL_CAPTCHA_KEY is set.
# Choices: capsolver (default — best 2026 coverage / speed / price)
#          nopecha (free dev tier; smaller coverage)
#          twocaptcha (human-powered fallback; broadest type support)
#          none (don't escalate even if key is present)
SCRAPPER_TOOL_CAPTCHA_PAID_FALLBACK=capsolver

# Per-solve timeout in seconds.
SCRAPPER_TOOL_CAPTCHA_TIMEOUT_S=120

# =============================================================================
# Live integration tests (opt-in)
# =============================================================================

# Enables tests/integration/test_live_probes.py (Patterns A/B/C live probes).
# SCRAPPER_TOOL_LIVE=1

# Enables tests/integration/test_agent_live.py (Pattern E live probes).
# Both must be set together.
# SCRAPPER_TOOL_AGENT=1
